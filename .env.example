# my-neuro environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_API_KEY=
LLM_API_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── SiliconFlow (cloud TTS / shared API key) ──────────────────────────────────
SILICONFLOW_API_KEY=

# ── Aliyun TTS (optional) ─────────────────────────────────────────────────────
ALIYUN_TTS_API_KEY=

# ── Cloud TTS custom voice ID (SiliconFlow CosyVoice) ─────────────────────────
CLOUD_TTS_VOICE=speech:fake-neuro:j3qz9ij4k2:kquiiycgizgaoxeujypx

# ── Vision model (optional) ───────────────────────────────────────────────────
VISION_API_KEY=
VISION_API_URL=
VISION_MODEL=

# ── API Gateway (optional) ────────────────────────────────────────────────────
API_GATEWAY_API_KEY=

# ── Baidu ASR (optional) ──────────────────────────────────────────────────────
BAIDU_ASR_APPKEY=

# ── MemOS LLM (memos_config.json) ─────────────────────────────────────────────
# SILICONFLOW_API_KEY above is reused for memos LLM (DeepSeek via SiliconFlow)
OPENROUTER_API_KEY=
