    "baidu_asr": {
      "enabled": false,
      "url": "ws://vop.baidu.com/realtime_asr",
      "appid": 121933442,
      "appkey": "${BAIDU_ASR_APPKEY}",
      "dev_pid": 15372
    }
  },
  "game": {
    "Minecraft": {
      "enabled": false,
